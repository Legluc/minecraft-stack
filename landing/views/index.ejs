<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= serverName %></title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body
    class="bg-gray-900 text-white min-h-screen flex flex-col items-center justify-center px-4"
  >
    <div class="max-w-2xl w-full text-center">
      <!-- Header -->
      <div class="mb-10">
        <h1 class="text-5xl font-bold text-green-400 mb-3">
          ⛏ <%= serverName %>
        </h1>
        <p class="text-gray-400 text-lg">
          Bienvenue sur notre serveur Minecraft communautaire
        </p>
      </div>

      <!-- Connection info -->
      <div class="bg-gray-800 rounded-2xl p-6 mb-8 border border-gray-700">
        <h2 class="text-xl font-semibold text-green-300 mb-4">Se connecter</h2>
        <div
          class="flex items-center justify-center gap-3 bg-gray-900 rounded-xl px-5 py-3 font-mono text-green-400 text-lg"
        >
          <span><%= serverAddress %>:<%= serverPort %></span>
        </div>
        <p class="text-gray-500 text-sm mt-3">Version : Java Edition — Paper</p>
      </div>

      <!-- Rules -->
      <div class="bg-gray-800 rounded-2xl p-6 border border-gray-700 text-left">
        <h2 class="text-xl font-semibold text-green-300 mb-4">
          Règles du serveur
        </h2>
        <ul class="space-y-2 text-gray-300">
          <li class="flex items-start gap-2">
            <span class="text-green-400">✔</span> Respecter tous les joueurs
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-400">✔</span> Pas de triche ni de hack
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-400">✔</span> Ne pas griffer les
            constructions des autres
          </li>
          <li class="flex items-start gap-2">
            <span class="text-green-400">✔</span> Bonne humeur obligatoire !
          </li>
        </ul>
      </div>
    </div>

    <footer class="mt-12 text-gray-600 text-sm">
      &copy; <%= new Date().getFullYear() %> <%= serverName %>
    </footer>
  </body>
</html>
